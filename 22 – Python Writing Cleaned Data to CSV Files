# Clean Customer Names (strip + title)

import csv

cleaned_rows = []
with open(r"C:\Users\chand\Downloads\customer_data.csv", ) as f:
    reader = csv.DictReader(f)

    for row in reader:
        row["customer_name"] = row["customer_salary"].strip().title()
        cleaned_rows.append(row)

#print(cleaned_rows)
with open("cleaned_customers.csv","w", newline="") as f:
    writer = csv.DictWriter(f, fieldnames=reader.fieldnames)
    writer.writeheader()
    writer.writerows(cleaned_rows)

print("Cleaned CSV Created : cleaned_customers.csv")

