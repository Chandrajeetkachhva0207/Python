# 9. TWO POINTER (PAIR SUM)
# =========================
arr = [1, 2, 3, 4, 6]
target = 6

left, right = 0, len(arr) - 1

while left < right:
    s = arr[left] + arr[right]
    if s == target:
        print("Pair:", arr[left], arr[right])
        break
    elif s < target:
        left += 1
    else:
        right -= 1


# =========================
# 10. BINARY SEARCH
# =========================
arr = [1, 2, 3, 4, 5, 6, 7]
target = 5

low, high = 0, len(arr) - 1

while low <= high:
    mid = (low + high) // 2
    if arr[mid] == target:
        print("Found at index:", mid)
        break
    elif arr[mid] < target:
        low = mid + 1
    else:
        high = mid - 1


